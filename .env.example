# ---------------------------------------------------------------------------
# Moneycontrol IT Scraper -- environment configuration
# Copy this file to `.env` and adjust values. Every variable is optional;
# defaults are shown below and live in scraper/config/settings.py.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# SQLite (default). Path is created automatically.
DATABASE_URL=sqlite:///data/scraper.db
# PostgreSQL example (requires psycopg2-binary in requirements.txt):
# DATABASE_URL=postgresql://user:password@localhost:5432/moneycontrol

# --- Scraping behaviour ------------------------------------------------------
# Minimum seconds between HTTP requests (politeness / rate limiting).
REQUEST_DELAY_SECONDS=1.5
# Extra random jitter (0..N seconds) added to each delay.
REQUEST_JITTER_SECONDS=1.0
# Per-request timeout in seconds.
REQUEST_TIMEOUT_SECONDS=40
# Number of retry attempts for a failed request (exponential backoff).
MAX_RETRIES=4
# Base seconds for exponential backoff (2 -> 2s, 4s, 8s, ...).
RETRY_BACKOFF_BASE=2.0

# --- Static data caching -----------------------------------------------------
# Static profile data (name, summary, website, ...) is re-scraped only when
# missing or older than this many days. Dynamic data refreshes on every run.
STATIC_REFRESH_DAYS=30

# --- Index / sector selection -------------------------------------------------
# Comma-separated list of index keys to scrape (see scraper/config/indices.py).
# Leave empty to use the default set.
# INDICES=nifty_it,nifty_midcap_150
# NSE "Industry" values treated as IT (comma separated, case-insensitive).
IT_INDUSTRY_VALUES=Information Technology
# Moneycontrol sector names treated as IT (fallback when NSE industry missing).
IT_MC_SECTOR_VALUES=Software & IT Services,IT Services & Consulting

# --- Export -------------------------------------------------------------------
EXPORT_DIR=exports
EXPORT_EXCEL=true
EXPORT_CSV=false

# --- Logging ------------------------------------------------------------------
LOG_DIR=logs
LOG_LEVEL=INFO
